---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  locale?: string;
}

const { title, description, keywords, image, locale } = Astro.props;
const canonicalURL = Astro.url;
const ogLocale = locale || 'en_US';
const ogImage = image ?? 'https://wordcountergo.com/og-default.svg';
const siteKeywords = keywords || 'word counter, free word counter, online word counter, word counter tool, character counter, word count, character count, word counter online, count words, text counter';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="wordcountergo" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#fb6514" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteKeywords} />
    <meta name="author" content="wordcountergo.com" />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="wordcountergo.com — Free Word Counter Tool" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@wordcountergo" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="wordcountergo.com — Free Word & Character Counter Tool" />

    <link rel="canonical" href={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DP5Y7NBTMG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DP5Y7NBTMG');
    </script>
    <script>
      (function() {
        try {
          if (localStorage.getItem('wordcountergo-dark') === 'true') {
            document.documentElement.classList.add('dark');
            document.documentElement.style.colorScheme = 'dark';
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="bg-canvas-soft text-ink font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-link focus:text-white focus:rounded-md focus:text-body-sm focus:no-underline">
      Skip to main content
    </a>
    <slot />

    <script>
      const LOCALES = { en: 'English', fr: 'Fran\u00E7ais', es: 'Espa\u00F1ol', de: 'Deutsch', it: 'Italiano', pt: 'Portugu\u00EAs', nl: 'Nederlands', pl: 'Polski', sv: 'Svenska', ro: 'Rom\u00E2n\u0103', el: '\u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC', ru: '\u0420\u0443\u0441\u0441\u043A\u0438\u0439', ja: '\u65E5\u672C\u8A9E', 'zh-CN': '\u4E2D\u6587\u7B80\u4F53', hi: '\u0939\u093F\u0928\u094D\u0926\u0940', ur: '\u0627\u064F\u0631\u062F\u0648' };
      const LOCALE_KEYS = Object.keys(LOCALES);

      function getLocale() {
        try {
          const saved = localStorage.getItem('wordcountergo-locale');
          if (saved && LOCALE_KEYS.includes(saved)) return saved;
        } catch {}
        try {
          const lang = navigator.language;
          if (lang.startsWith('it')) return 'it';
          if (lang.startsWith('pt')) return 'pt';
          if (lang.startsWith('nl')) return 'nl';
          if (lang.startsWith('pl')) return 'pl';
          if (lang.startsWith('sv')) return 'sv';
          if (lang.startsWith('ro')) return 'ro';
          if (lang.startsWith('el')) return 'el';
          if (lang.startsWith('ru')) return 'ru';
          if (lang.startsWith('fr')) return 'fr';
          if (lang.startsWith('es')) return 'es';
          if (lang.startsWith('de')) return 'de';
          if (lang.startsWith('ja')) return 'ja';
          if (lang.startsWith('zh')) return 'zh-CN';
          if (lang.startsWith('hi')) return 'hi';
          if (lang.startsWith('ur')) return 'ur';
        } catch {}
        return 'en';
      }

      const LOCALE_DIR = { ur: 'rtl' };

      async function applyTranslations(locale) {
        try {
          const res = await fetch('/locales/' + locale + '.json');
          if (!res.ok) return;
          const t = await res.json();

          document.documentElement.lang = locale === 'zh-CN' ? 'zh-Hans' : locale;
          document.documentElement.dir = LOCALE_DIR[locale] || 'ltr';

          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            const attr = el.getAttribute('data-i18n-attr');
            let text = t[key];
            if (text === undefined) return;
            const count = el.getAttribute('data-i18n-count');
            if (count !== null) {
              const n = parseInt(count);
              if (n !== 1 && t[key + '-plural']) text = t[key + '-plural'];
              text = text.replace('{count}', count);
            }
            const year = el.getAttribute('data-i18n-year');
            if (year !== null) text = text.replace('{year}', year);
            const find = el.getAttribute('data-i18n-find');
            if (find !== null) text = text.replace('{find}', find);
            if (attr) {
              const target = attr === 'self' ? el : el.querySelector('[' + attr + ']') || el;
              target.setAttribute(attr, text);
            } else {
              el.textContent = text;
            }
          });
        } catch {}
      }

      const locale = getLocale();
      applyTranslations(locale);

      if (locale !== 'en') {
        document.documentElement.classList.add('translated');
      }

      var localeSource;
      try { localeSource = localStorage.getItem('wordcountergo-locale-source'); } catch {}

      if (localeSource !== 'manual') {
        fetch('/api/locale').then(function(r) { return r.json(); }).then(function(data) {
          if (data.locale && data.locale !== locale) {
            try {
              localStorage.setItem('wordcountergo-locale', data.locale);
              localStorage.setItem('wordcountergo-locale-source', 'geo');
            } catch {}
            location.reload();
          }
        }).catch(function() {});
      }
    </script>
  </body>
</html>
