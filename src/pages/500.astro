---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="500 — Server Error | wordcountergo.com"
  description="Server error. Something went wrong on our end. Please try again later or use our free word counter."
  keywords="500, server error, word counter, free word counter"
>
  <Header />

  <main id="main-content" aria-label="Main content" class="mx-auto max-w-[900px] px-4 sm:px-6 pt-16 sm:pt-24 pb-16 sm:pb-32">
    <div class="text-center">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-canvas-soft text-caption text-body font-mono uppercase tracking-wider mb-4 border border-hairline">Error 500</span>
      <h1 class="text-display-xl max-sm:text-[36px] max-sm:leading-[40px] sm:text-[56px] sm:leading-[56px] font-semibold tracking-[-2.4px] text-ink">Server Error.</h1>
      <p class="mt-3 text-body-lg text-body max-w-md mx-auto">Something went wrong on our end. Please try again shortly.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="inline-flex items-center justify-center h-12 sm:h-10 px-6 sm:px-5 rounded-full bg-link text-white text-body-sm font-medium hover:bg-link-deep transition-colors no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link w-full sm:w-auto">
          Go to Word Counter
        </a>
        <a href="/contact" class="inline-flex items-center justify-center h-12 sm:h-10 px-6 sm:px-5 rounded-full bg-canvas border border-hairline text-body text-body-sm font-medium hover:bg-canvas-soft-2 transition-colors no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link w-full sm:w-auto">
          Report Issue
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
