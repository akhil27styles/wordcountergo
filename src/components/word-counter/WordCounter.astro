            <span class="text-caption text-mute" data-i18n="tool.details.avg-length">Avg. word length</span>
            <span id="stat-avg-length" class="text-body-sm text-ink font-semibold tabular-nums">0</span>
          </div>
        </div>
      </div>
    </div>

    <div class="px-4 sm:px-6 pb-4 sm:pb-6">
      <div class="bg-canvas-soft rounded-lg p-4 border border-hairline">
        <p class="text-caption-mono font-mono text-mute uppercase tracking-wider mb-3" data-i18n="tool.letter-frequency.title">Letter Frequency</p>
        <div id="letter-freq" class="flex flex-wrap gap-1">
          <span class="text-caption text-mute" data-i18n="tool.letter-frequency.empty">Start typing to see letter frequency...</span>
        </div>
      </div>
    </div>
    <div id="loading-overlay" class="absolute inset-0 z-10 bg-canvas/90 rounded-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">
      <div class="text-center px-4">
        <div class="mx-auto mb-3 w-8 h-8 border-2 border-link border-t-transparent rounded-full animate-spin"></div>
        <p class="text-body-md text-link font-semibold" data-i18n="tool.loading.text">Parsing file...</p>
      </div>
    </div>
    <div id="drop-zone" class="absolute inset-0 z-10 bg-canvas/90 border-2 border-dashed border-link rounded-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">
      <div class="text-center px-4">
        <svg class="mx-auto mb-2" aria-hidden="true" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <p class="text-body-md text-link font-semibold" data-i18n="tool.drop.title">Drop file here</p>
        <p class="text-caption text-mute mt-1" data-i18n="tool.drop.formats">.txt, .docx, .doc, .pdf, .png, .jpg</p>
      </div>
    </div>
  </div>
</div>

<div id="toast" role="status" aria-live="polite" class="fixed bottom-4 sm:bottom-6 right-4 sm:right-6 left-4 sm:left-auto z-50 px-4 py-3 sm:px-4 sm:py-2 rounded-lg bg-ink text-canvas text-body-sm font-medium shadow-level-4 transition-all duration-300 opacity-0 translate-y-2 pointer-events-none text-center sm:text-start" data-i18n="tool.copy-toast">
  Copied!
</div>

<script>
  type CaseType = 'sentence' | 'lower' | 'upper' | 'title' | 'toggle';

  const textarea = document.getElementById('text-input') as HTMLTextAreaElement;

  const statWords = document.getElementById('stat-words')!;
  const statChars = document.getElementById('stat-chars')!;
  const statSpaces = document.getElementById('stat-spaces')!;
  const statSentences = document.getElementById('stat-sentences')!;
  const statParagraphs = document.getElementById('stat-paragraphs')!;
  const statLines = document.getElementById('stat-lines')!;
  const statPages = document.getElementById('stat-pages')!;
  const statUnique = document.getElementById('stat-unique')!;
  const statReading = document.getElementById('stat-reading')!;
  const statSpeaking = document.getElementById('stat-speaking')!;
  const statFlesch = document.getElementById('stat-flesch')!;
  const statFK = document.getElementById('stat-fk-grade')!;
  const statGunning = document.getElementById('stat-gunning')!;
  const statAvgSentence = document.getElementById('stat-avg-sentence')!;
  const statAvgSyllables = document.getElementById('stat-avg-syllables')!;
  const statLongest = document.getElementById('stat-longest')!;
  const statShortest = document.getElementById('stat-shortest')!;
  const statSyllables = document.getElementById('stat-syllables')!;
  const statAvgLength = document.getElementById('stat-avg-length')!;

  const keywordList = document.getElementById('keyword-list')!;
  const letterFreq = document.getElementById('letter-freq')!;

  const goalWordsCount = document.getElementById('goal-words-count')!;
  const goalCharsCount = document.getElementById('goal-chars-count')!;
  const goalWordsBar = document.getElementById('goal-words-bar')!;
  const goalCharsBar = document.getElementById('goal-chars-bar')!;
  const goalWordTarget = document.getElementById('goal-word-target') as HTMLSelectElement;
  const goalCharTarget = document.getElementById('goal-char-target') as HTMLSelectElement;

  const socialTwitter = document.getElementById('social-twitter')!;
  const socialGoogle = document.getElementById('social-google')!;
  const socialInstagram = document.getElementById('social-instagram')!;
  const socialTiktok = document.getElementById('social-tiktok')!;
  const socialYoutube = document.getElementById('social-youtube')!;
  const socialTwitterBar = document.getElementById('social-twitter-bar')!;
  const socialGoogleBar = document.getElementById('social-google-bar')!;
  const socialInstagramBar = document.getElementById('social-instagram-bar')!;
  const socialTiktokBar = document.getElementById('social-tiktok-bar')!;
  const socialYoutubeBar = document.getElementById('social-youtube-bar')!;

  function segments(text: string, granularity: 'word' | 'sentence' | 'grapheme' = 'word'): string[] {
    try {
      const seg = new Intl.Segmenter(undefined, { granularity });
      return [...seg.segment(text)].map(s => s.segment);
    } catch {
      if (granularity === 'word') return text.match(/[\p{L}\p{M}'\u2000-\u206F\u2E00-\u2E7F'!@#$%^&*()_+\-=\[\]{};:"\\|,.<>\/?`~]+/gu) || [];
      if (granularity === 'sentence') return text.match(/[^.!?\n]+[.!?]*/g) || [];
      return [...text];
    }
  }

  function getWords(text: string): string[] {
    try {
      return segments(text, 'word').filter(w => /[\p{L}\p{M}]/u.test(w));
    } catch {
      return text.match(/[\p{L}\p{M}']+/gu) || [];
    }
  }

  function countSyllables(word: string): number {
    word = word.toLowerCase().replace(/[^a-z]/g, '');
    if (!word) return 0;
    if (word.length <= 3) return 1;
    word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
    word = word.replace(/^y/, '');
    const matches = word.match(/[aeiouy]{1,2}/g);
    return matches ? matches.length : 1;
  }

  function fleschReadingEase(totalSyllables: number, totalWords: number, totalSentences: number): number {
    if (totalWords === 0 || totalSentences === 0) return 0;
    return 206.835 - 1.015 * (totalWords / totalSentences) - 84.6 * (totalSyllables / totalWords);
  }

  function fleschKincaid(totalSyllables: number, totalWords: number, totalSentences: number): number {
    if (totalWords === 0 || totalSentences === 0) return 0;
    return 0.39 * (totalWords / totalSentences) + 11.8 * (totalSyllables / totalWords) - 15.59;
  }

  function gunningFog(totalWords: number, totalSentences: number, complexWords: number): number {
    if (totalSentences === 0) return 0;
    return 0.4 * ((totalWords / totalSentences) + 100 * (complexWords / totalWords));
  }

  function update() {
    const text = textarea.value;
    const charsNoSpace = text.replace(/\s/g, '').length;
    const chars = charsNoSpace;
    const words = getWords(text);
    const wordCount = words.length;
    const uniqueWords = new Set(words.map(w => w.toLowerCase())).size;

    const lines = charsNoSpace > 0 ? text.split('\n').length : 0;
    const paragraphs = text ? text.split(/\n\s*\n/).filter(p => p.trim()).length : 0;
    const sentences = segments(text, 'sentence').filter(s => s.trim()).length;

    const pages = wordCount > 0 ? Math.max(1, Math.round(wordCount / 250)) : 0;

    const syllables = words.reduce((s, w) => s + countSyllables(w), 0);
    const complexWords = words.filter(w => countSyllables(w) >= 3).length;

    statWords.textContent = String(wordCount);
    statChars.textContent = String(chars);
  statSpaces.textContent = String(text.length - charsNoSpace);
  statSentences.textContent = String(sentences);
    statParagraphs.textContent = String(paragraphs);
    statLines.textContent = String(lines);
    statPages.textContent = String(pages);
    statUnique.textContent = String(uniqueWords);
    statSyllables.textContent = String(syllables);

    const readingTime = wordCount > 0 ? Math.ceil(wordCount / 200) : 0;
    const speakingTime = wordCount > 0 ? Math.ceil(wordCount / 130) : 0;
    statReading.textContent = `${readingTime} min`;
    statSpeaking.textContent = `${speakingTime} min`;

    const avgSentence = sentences > 0 ? (wordCount / sentences) : 0;
    const avgSyllableWord = wordCount > 0 ? (syllables / wordCount) : 0;
    const avgWordLength = wordCount > 0 ? words.reduce((s, w) => s + w.length, 0) / wordCount : 0;

    statAvgSentence.textContent = avgSentence.toFixed(1);
    statAvgSyllables.textContent = avgSyllableWord.toFixed(1);
    statAvgLength.textContent = avgWordLength.toFixed(1);

    if (wordCount > 0 && sentences > 0) {
      const flesch = fleschReadingEase(syllables, wordCount, sentences);
      const fk = fleschKincaid(syllables, wordCount, sentences);
      const gunning = gunningFog(wordCount, sentences, complexWords);
      statFlesch.textContent = flesch.toFixed(1);
      statFK.textContent = fk.toFixed(1);
      statGunning.textContent = gunning.toFixed(1);
    } else {
      statFlesch.textContent = '-'; statFK.textContent = '-'; statGunning.textContent = '-';
    }

    if (wordCount > 0) {
      const sorted = [...words].sort((a, b) => b.length - a.length);
      statLongest.textContent = sorted[0];
      statShortest.textContent = sorted[sorted.length - 1];
    } else {
      statLongest.textContent = '-'; statShortest.textContent = '-';
    }

    const wordFreq = new Map<string, number>();
    words.forEach(w => {
      const lower = w.toLowerCase();
      wordFreq.set(lower, (wordFreq.get(lower) || 0) + 1);
    });
    const sortedKeywords = [...wordFreq.entries()].sort((a, b) => b[1] - a[1]).slice(0, 10);

    if (sortedKeywords.length > 0) {
      keywordList.innerHTML = sortedKeywords.map(([word, count]) => {
        const pct = ((count / wordCount) * 100).toFixed(1);
        return `<div class="flex items-center justify-between py-1">
          <span class="text-body-sm text-ink truncate max-w-[60%]">${escapeHtml(word)}</span>
          <span class="text-caption tabular-nums text-mute">${count}x (${pct}%)</span>
        </div>`;
      }).join('');
    } else {
      keywordList.innerHTML = '<p class="text-caption text-mute">Start typing to see keywords...</p>';
    }

    const letterCounts = new Map<string, number>();
    let totalLetters = 0;
    for (const c of text) {
      if (/[\p{L}]/u.test(c)) {
        letterCounts.set(c, (letterCounts.get(c) || 0) + 1);
        totalLetters++;
      }
    }
    const sortedLetters = [...letterCounts.entries()].sort((a, b) => b[1] - a[1]);
    if (sortedLetters.length > 0) {
      const maxCount = sortedLetters[0][1];
      letterFreq.innerHTML = sortedLetters.map(([letter, count]) => {
        const pct = (count / totalLetters) * 100;
        const barWidth = (count / maxCount) * 100;
        return `<div class="flex items-center gap-2 text-caption">
          <span class="font-semibold text-ink w-4 text-center">${letter}</span>
          <div class="w-16 h-2 bg-hairline rounded-full overflow-hidden">
            <div class="h-full bg-link rounded-full transition-all" style="width: ${barWidth}%"></div>
          </div>
          <span class="tabular-nums text-mute">${count} (${pct.toFixed(1)}%)</span>
        </div>`;
      }).join('');
    } else {
      letterFreq.innerHTML = '<span class="text-caption text-mute">Start typing to see letter frequency...</span>';
    }

    const wordTarget = parseInt(goalWordTarget.value);
    const charTarget = parseInt(goalCharTarget.value);
    const wordPct = Math.min(100, (wordCount / wordTarget) * 100);
    const charPct = Math.min(100, (chars / charTarget) * 100);
    goalWordsCount.textContent = String(wordCount);
    goalCharsCount.textContent = String(chars);
    goalWordsBar.style.width = `${wordPct}%`;
    goalCharsBar.style.width = `${charPct}%`;
    if (wordPct >= 100) goalWordsBar.className = 'h-full bg-error rounded-full transition-all duration-300';
    else goalWordsBar.className = 'h-full bg-cyan rounded-full transition-all duration-300';
    if (charPct >= 100) goalCharsBar.className = 'h-full bg-error rounded-full transition-all duration-300';
    else goalCharsBar.className = 'h-full bg-violet rounded-full transition-all duration-300';

    function socialBar(limit: number, el: HTMLElement, bar: HTMLElement, name: string) {
      el.textContent = `${chars} / ${limit}`;
      const pct = Math.min(100, (chars / limit) * 100);
      bar.style.width = `${pct}%`;
      let status: string;
      if (pct >= 100) { bar.style.backgroundColor = '#ee0000'; status = 'over limit'; }
      else if (pct >= 90) { bar.style.backgroundColor = '#f5a623'; status = 'near limit'; }
      else { bar.style.backgroundColor = '#50e3c2'; status = 'within limit'; }
      bar.setAttribute('aria-label', `${name}: ${chars} of ${limit} characters, ${status}`);
    }
    socialBar(280, socialTwitter, socialTwitterBar, 'Twitter');
    socialBar(160, socialGoogle, socialGoogleBar, 'Google Meta');
    socialBar(2200, socialInstagram, socialInstagramBar, 'Instagram');
    socialBar(2200, socialTiktok, socialTiktokBar, 'TikTok');
    socialBar(5000, socialYoutube, socialYoutubeBar, 'YouTube');
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  textarea.addEventListener('input', update);

  goalWordTarget.addEventListener('change', update);
  goalCharTarget.addEventListener('change', update);

  function showToast(msg: string) {
    const toast = document.getElementById('toast')!;
    toast.textContent = msg;
    toast.classList.remove('opacity-0', 'translate-y-2');
    toast.classList.add('opacity-100', 'translate-y-0');
    setTimeout(() => {
      toast.classList.remove('opacity-100', 'translate-y-0');
      toast.classList.add('opacity-0', 'translate-y-2');
    }, 2000);
  }

  const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
  const redoBtn = document.getElementById('redo-btn') as HTMLButtonElement;
  let historyStack: string[] = [];
  let historyIndex = -1;
  let historyTimer: ReturnType<typeof setTimeout> | null = null;
  const MAX_HISTORY = 50;

  function pushHistory(text: string) {
    if (text === historyStack[historyIndex]) return;
    if (historyIndex < historyStack.length - 1) {
      historyStack = historyStack.slice(0, historyIndex + 1);
    }
    historyStack.push(text);
    if (historyStack.length > MAX_HISTORY) historyStack.shift();
    historyIndex = historyStack.length - 1;
    updateUndoRedoButtons();
  }

  function cancelHistoryTimer() {
    if (historyTimer) { clearTimeout(historyTimer); historyTimer = null; }
  }

  function updateUndoRedoButtons() {
    undoBtn.disabled = historyIndex <= 0;
    redoBtn.disabled = historyIndex >= historyStack.length - 1;
  }

  function undo() {
    if (historyIndex <= 0) return;
    cancelHistoryTimer();
    historyIndex--;
    textarea.value = historyStack[historyIndex];
    update();
    updateUndoRedoButtons();
  }

  function redo() {
    if (historyIndex >= historyStack.length - 1) return;
    cancelHistoryTimer();
    historyIndex++;
    textarea.value = historyStack[historyIndex];
    update();
    updateUndoRedoButtons();
  }

  undoBtn.addEventListener('click', undo);
  redoBtn.addEventListener('click', redo);

  document.addEventListener('keydown', (e) => {
    const isMeta = e.metaKey || e.ctrlKey;
    if (isMeta && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); return; }
    if ((isMeta && e.key === 'z' && e.shiftKey) || (isMeta && e.key === 'y')) { e.preventDefault(); redo(); return; }
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(textarea.value).then(() => showToast('Copied!')).catch(() => {});
  });

  document.getElementById('clear-btn')!.addEventListener('click', () => {
    pushHistory(textarea.value);
    cancelHistoryTimer();
    textarea.value = '';
    update();
    textarea.focus();
  });

  document.getElementById('download-btn')!.addEventListener('click', () => {
    const blob = new Blob([textarea.value], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'wordcountergo-export.txt';
    a.click();
    URL.revokeObjectURL(url);
  });

  document.querySelectorAll('.case-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = (btn as HTMLElement).dataset.case as CaseType;
      const text = textarea.value;
      if (!text) return;
      pushHistory(text);
      cancelHistoryTimer();
      const selectionStart = textarea.selectionStart;
      const selectionEnd = textarea.selectionEnd;
      const selectedText = text.substring(selectionStart, selectionEnd);
      const targetText = selectedText || text;

      let result: string;
      switch (type) {
        case 'sentence':
          result = targetText.replace(/(^\s*\w|[.!?]\s*\w)/g, c => c.toUpperCase());
          break;
        case 'lower':
          result = targetText.toLowerCase();
          break;
        case 'upper':
          result = targetText.toUpperCase();
          break;
        case 'title':
          result = targetText.replace(/\w\S*/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
          break;
        case 'toggle':
          result = [...targetText].map(c => c === c.toUpperCase() ? c.toLowerCase() : c.toUpperCase()).join('');
          break;
        default:
          result = targetText;
      }

      if (selectedText) {
        textarea.setRangeText(result, selectionStart, selectionEnd, 'end');
      } else {
        textarea.value = result;
      }
      update();
    });
  });

  try {
    const saved = localStorage.getItem('wordcountergo-text');
    if (saved) { textarea.value = saved; update(); }
  } catch {}

  pushHistory(textarea.value);

  textarea.addEventListener('input', () => {
    try { localStorage.setItem('wordcountergo-text', textarea.value); } catch {}
    if (historyTimer) clearTimeout(historyTimer);
    historyTimer = setTimeout(() => pushHistory(textarea.value), 500);
  });

  document.getElementById('replace-btn')!.addEventListener('click', () => {
    const findInput = document.getElementById('find-input') as HTMLInputElement;
    const replaceInput = document.getElementById('replace-input') as HTMLInputElement;
    const find = findInput.value;
    const replace = replaceInput.value;
    if (!find) { showToast('Enter text to find'); return; }
    try {
      const escaped = find.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp(escaped, 'gi');
      const count = (textarea.value.match(regex) || []).length;
      const result = textarea.value.replace(regex, replace);
      if (count > 0) {
        pushHistory(textarea.value);
        cancelHistoryTimer();
        textarea.value = result;
        update();
        showToast(`Replaced ${count} occurrence${count !== 1 ? 's' : ''}`);
      } else {
        showToast(`No matches found for "${find}"`);
      }
    } catch {}
  });

  function findEOCD(data: DataView): number {
    const len = data.byteLength;
    const searchStart = Math.max(0, len - 65557);
    for (let i = len - 22; i >= searchStart; i--) {
      if (data.getUint32(i, true) === 0x06054b50) return i;
    }
    return -1;
  }

  async function parseDocx(buffer: ArrayBuffer): Promise<string> {
    const data = new DataView(buffer);
    const eocdOffset = findEOCD(data);
    if (eocdOffset === -1) throw new Error('Invalid DOCX (ZIP) file');

    const cdOffset = data.getUint32(eocdOffset + 16, true);
    const cdSize = data.getUint32(eocdOffset + 12, true);

    let localOffset = -1;
    let compSize = 0;
    let method = 0;
    let pos = cdOffset;
    const cdEnd = cdOffset + cdSize;

    while (pos < cdEnd) {
      if (data.getUint32(pos, true) !== 0x02014b50) break;
      const nameLen = data.getUint16(pos + 28, true);
      const extraLen = data.getUint16(pos + 30, true);
      const commentLen = data.getUint16(pos + 32, true);
      const fileName = new TextDecoder().decode(new Uint8Array(buffer, pos + 46, nameLen));

      if (fileName === 'word/document.xml') {
        localOffset = data.getUint32(pos + 42, true);
        compSize = data.getUint32(pos + 20, true);
        method = data.getUint16(pos + 10, true);
        break;
      }
      pos += 46 + nameLen + extraLen + commentLen;
    }

    if (localOffset === -1) throw new Error('word/document.xml not found in DOCX');
    if (data.getUint32(localOffset, true) !== 0x04034b50) throw new Error('Invalid local file header');

    const lNameLen = data.getUint16(localOffset + 26, true);
    const lExtraLen = data.getUint16(localOffset + 28, true);
    const dataStart = localOffset + 30 + lNameLen + lExtraLen;

    let xmlBuffer: ArrayBuffer;
    if (method === 0) {
      xmlBuffer = buffer.slice(dataStart, dataStart + compSize);
    } else if (method === 8) {
      const compressed = new Uint8Array(buffer, dataStart, compSize);
      const ds = new DecompressionStream('deflate-raw');
      const blob = new Blob([compressed]);
      const stream = blob.stream().pipeThrough(ds);
      xmlBuffer = await new Response(stream).arrayBuffer();
    } else {
      throw new Error(`Unsupported compression method: ${method}`);
    }

    const xmlText = new TextDecoder().decode(xmlBuffer);
    const cleaned = xmlText.replace(/<w:/g, '<').replace(/<\/w:/g, '</');
    const doc = new DOMParser().parseFromString(cleaned, 'text/xml');

    const paragraphs = doc.querySelectorAll('p');
    const results: string[] = [];
    for (const p of paragraphs) {
      const tElements = p.querySelectorAll('t');
      const text = Array.from(tElements).map(t => t.textContent || '').join('');
      results.push(text);
    }
    return results.join('\n');
  }

  function extractPlainText(raw) {
    const results = [];
    const tjRegex = /\(((?:[^()\\]|\\.)*)\)\s*Tj/g;
    let m;
    while ((m = tjRegex.exec(raw)) !== null) {
      const txt = m[1].replace(/\\([nrt\\()])/g, function(_, c) {
        return c === 'n' ? '\n' : c === 'r' ? '\r' : c === 't' ? '\t' : c;
      });
      if (txt.trim().length > 0) results.push(txt);
    }
    if (results.length > 0) return results.join('\n');

    const lines = [];
    const matches = raw.match(/[\x20-\x7E\u00A0-\u00FF]{4,}/g);
    if (matches) {
      for (let i = 0; i < matches.length; i++) {
        if (/^[\d\s]+$/.test(matches[i]) || /^\/\w/.test(matches[i])) continue;
        const trimmed = matches[i].replace(/[^\w\s,.!?;:'"()\-\/#@$%&*]/g, ' ').trim();
        if (trimmed.length > 8 && trimmed.split(/\s+/).length >= 3) lines.push(trimmed);
      }
    }
    return lines.join('\n');
  }

  async function parsePdf(buffer) {
    try {
      const pdfjsLib = await import(window.location.origin + '/pdf.mjs');
      pdfjsLib.GlobalWorkerOptions.workerSrc = '/pdf-worker.mjs';

      const pdfPromise = pdfjsLib.getDocument({ data: buffer }).promise;
      const pdf = await Promise.race([
        pdfPromise,
        new Promise(function(_, reject) {
          setTimeout(() => reject(new Error('PDF.js worker timed out')), 15000);
        })
      ]);

      const textParts = [];
      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        const page = await pdf.getPage(pageNum);
        const textContent = await page.getTextContent();
        const pageText = textContent.items.map(function(item) {
          return 'str' in item ? item.str : '';
        }).join(' ');
        textParts.push(pageText);
      }

      const result = textParts.join('\n\n');
      if (result.trim()) return result;
    } catch (e) {
      console.warn('PDF.js failed, trying raw extraction:', e);
    }

    const raw = new TextDecoder('latin-1').decode(new Uint8Array(buffer));
    return extractPlainText(raw);
  }

  const loadingOverlay = document.getElementById('loading-overlay');
  function showLoading(show) {
    loadingOverlay.classList.toggle('opacity-0', !show);
    loadingOverlay.classList.toggle('pointer-events-none', !show);
  }

  async function extractImageText(file) {
    const Tesseract = await import('tesseract.js');
    const worker = await Tesseract.createWorker('eng');
    const { data } = await worker.recognize(file);
    await worker.terminate();
    return data.text;
  }

  async function handleFile(file) {
    const ext = file.name.split('.').pop()?.toLowerCase();
    showLoading(true);
    try {
      let text;
      if (ext === 'txt') {
        text = await file.text();
      } else if (ext === 'docx') {
        const buffer = await file.arrayBuffer();
        text = await parseDocx(buffer);
      } else if (ext === 'doc') {
        showLoading(false);
        showToast('.doc files are not supported. Try saving as .docx');
        return;
      } else if (ext === 'pdf') {
        const buffer = await file.arrayBuffer();
        text = await parsePdf(buffer);
        if (!text.trim()) {
          showLoading(false);
          showToast('This PDF format could not be read. The text may be in images or use an unsupported encoding.');
          return;
        }
      } else if (ext === 'png' || ext === 'jpg' || ext === 'jpeg') {
        text = await extractImageText(file);
        if (!text.trim()) {
          showLoading(false);
          showToast('No text could be extracted from this image.');
          return;
        }
      } else {
        showLoading(false);
        showToast('Unsupported format. Use .txt, .docx, .pdf, .png, or .jpg');
        return;
      }
      pushHistory(textarea.value || '');
      cancelHistoryTimer();
      textarea.value = text;
      update();
      showLoading(false);
      showToast(`Loaded ${file.name}`);
    } catch (e) {
      console.error('handleFile error:', e, 'file:', file.name);
      showLoading(false);
      showToast(`Could not read ${file.name}`);
    }
  }

  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  document.getElementById('upload-btn')!.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    await handleFile(file);
    fileInput.value = '';
  });

  const card = document.getElementById('word-counter-card')!;
  const dropZone = document.getElementById('drop-zone')!;
  let dragCounter = 0;

  function showDropZone(show: boolean) {
    dropZone.classList.toggle('opacity-0', !show);
    dropZone.classList.toggle('pointer-events-none', !show);
  }

  card.addEventListener('dragenter', (e) => {
    e.preventDefault();
    e.stopPropagation();
    dragCounter++;
    showDropZone(true);
  });

  card.addEventListener('dragover', (e) => {
    e.preventDefault();
    e.stopPropagation();
  });

  card.addEventListener('dragleave', (e) => {
    e.preventDefault();
    e.stopPropagation();
    dragCounter--;
    if (dragCounter <= 0) { dragCounter = 0; showDropZone(false); }
  });

  card.addEventListener('drop', async (e) => {
    e.preventDefault();
    e.stopPropagation();
    dragCounter = 0;
    showDropZone(false);
    const file = e.dataTransfer?.files?.[0];
    if (file) await handleFile(file);
  });

  update();
</script>
