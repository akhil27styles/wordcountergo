---
const currentPath = Astro.url.pathname;
---

<header aria-label="Site header" class="sticky top-0 z-50 h-16 bg-canvas/80 backdrop-blur-md border-b border-hairline before:absolute before:top-0 before:left-0 before:right-0 before:h-[3px] before:bg-link">
  <nav aria-label="Main navigation" class="mx-auto flex h-full max-w-[1400px] items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-display-sm font-semibold text-ink tracking-tight">wordcountergo.com</span>
    </a>

    <div id="nav-links" class="hidden sm:flex items-center gap-1 max-sm:z-50 max-sm:shadow-level-4">
      <a
        href="/"
        class="px-3 py-1.5 max-sm:py-3 text-body-sm text-body rounded-full hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link no-underline"
        class:list={{ 'bg-canvas-soft-2! text-ink!': currentPath === '/' }}
      >
        Word Counter
      </a>
      <a
        href="/faq"
        class="px-3 py-1.5 max-sm:py-3 text-body-sm text-body rounded-full hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link no-underline"
        class:list={{ 'bg-canvas-soft-2! text-ink!': currentPath.startsWith('/faq') }}
      >
        FAQ
      </a>
      <a
        href="/how-to-count-words"
        class="px-3 py-1.5 max-sm:py-3 text-body-sm text-body rounded-full hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link no-underline"
        class:list={{ 'bg-canvas-soft-2! text-ink!': currentPath.startsWith('/how-to-count-words') }}
      >
        Guide
      </a>
      <a
        href="/about"
        class="px-3 py-1.5 max-sm:py-3 text-body-sm text-body rounded-full hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link no-underline"
        class:list={{ 'bg-canvas-soft-2! text-ink!': currentPath.startsWith('/about') }}
      >
        About
      </a>
      <a
        href="/contact"
        class="px-3 py-1.5 max-sm:py-3 text-body-sm text-body rounded-full hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link no-underline"
        class:list={{ 'bg-canvas-soft-2! text-ink!': currentPath.startsWith('/contact') }}
      >
        Contact
      </a>
    </div>

    <div class="flex items-center gap-1">
      <div class="relative" id="lang-selector">
        <button id="lang-btn" class="inline-flex items-center justify-center w-8 h-8 max-sm:w-10 max-sm:h-10 rounded-full text-body hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link" aria-label="Language" aria-haspopup="true" aria-expanded="false">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </button>
        <div id="lang-dropdown" class="hidden absolute right-0 mt-1 w-40 bg-canvas border border-hairline rounded-lg shadow-level-4 py-1 z-50" role="menu" aria-label="Select language">
          <button data-lang="en" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">English</button>
          <button data-lang="fr" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">Français</button>
          <button data-lang="es" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">Español</button>
          <button data-lang="de" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">Deutsch</button>
          <button data-lang="ja" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">日本語</button>
          <button data-lang="zh-CN" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">中文简体</button>
          <button data-lang="hi" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">हिन्दी</button>
          <button data-lang="ur" class="w-full text-start px-3 py-1.5 text-body-sm text-body hover:bg-canvas-soft-2 transition-colors" role="menuitem">اُردُو</button>
        </div>
      </div>
      <button id="dark-toggle" class="inline-flex items-center justify-center w-8 h-8 max-sm:w-10 max-sm:h-10 rounded-full text-body hover:bg-canvas-soft-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link" aria-label="Toggle dark mode">
        <svg aria-hidden="true" id="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg aria-hidden="true" id="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
    <div id="menu-overlay" class="hidden sm:hidden fixed inset-0 z-40 bg-black/20 backdrop-blur-sm"></div>
    <button id="menu-btn" class="sm:hidden flex items-center justify-center w-10 h-10 text-body -me-1.5" aria-label="Toggle menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M2.5 5H17.5M2.5 10H17.5M2.5 15H17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </nav>
</header>

<script>
  const langSelector = document.getElementById('lang-selector')!;
  const langBtn = document.getElementById('lang-btn')!;
  const langDropdown = document.getElementById('lang-dropdown')!;
  const LOCALE_KEYS = ['en', 'fr', 'es', 'de', 'ja', 'zh-CN', 'hi', 'ur'];
  function getLocale() {
    try { const s = localStorage.getItem('wordcountergo-locale'); if (s && LOCALE_KEYS.includes(s)) return s; } catch {}
    return 'en';
  }
  langBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !langDropdown.classList.contains('hidden');
    langDropdown.classList.toggle('hidden', isOpen);
    langBtn.setAttribute('aria-expanded', String(!isOpen));
  });
  langDropdown.querySelectorAll('[data-lang]').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      try {
        localStorage.setItem('wordcountergo-locale', lang);
        localStorage.setItem('wordcountergo-locale-source', 'manual');
      } catch {}
      location.reload();
    });
  });
  document.addEventListener('click', (e) => {
    if (!langSelector.contains(e.target as Node)) {
      langDropdown.classList.add('hidden');
      langBtn.setAttribute('aria-expanded', 'false');
    }
  });

  const darkToggle = document.getElementById('dark-toggle')!;
  const sunIcon = document.getElementById('sun-icon')!;
  const moonIcon = document.getElementById('moon-icon')!;
  function applyDark(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
    sunIcon.classList.toggle('hidden', !dark);
    moonIcon.classList.toggle('hidden', dark);
  }
  const darkSaved = localStorage.getItem('wordcountergo-dark') === 'true';
  if (darkSaved) applyDark(true);
  darkToggle.addEventListener('click', () => {
    const isDark = !document.documentElement.classList.contains('dark');
    applyDark(isDark);
    try { localStorage.setItem('wordcountergo-dark', String(isDark)); } catch {}
  });

  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('nav-links');
  const overlay = document.getElementById('menu-overlay');
  if (btn && nav && overlay) {
    function toggleMenu(open?: boolean) {
      const isOpen = open ?? nav.classList.contains('hidden');
      nav.classList.toggle('hidden', !isOpen);
      nav.classList.toggle('flex', isOpen);
      nav.classList.toggle('flex-col', isOpen);
      nav.classList.toggle('absolute', isOpen);
      nav.classList.toggle('top-16', isOpen);
      nav.classList.toggle('left-0', isOpen);
      nav.classList.toggle('right-0', isOpen);
      nav.classList.toggle('bg-canvas', isOpen);
      nav.classList.toggle('border-b', isOpen);
      nav.classList.toggle('border-hairline', isOpen);
      nav.classList.toggle('p-4', isOpen);
      nav.classList.toggle('gap-2', isOpen);
      overlay.classList.toggle('hidden', !isOpen);
      document.body.style.overflow = isOpen ? 'hidden' : '';
    }
    btn.addEventListener('click', () => toggleMenu());
    overlay.addEventListener('click', () => toggleMenu(false));
    nav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => toggleMenu(false));
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 640) toggleMenu(false);
    });
  }
</script>
